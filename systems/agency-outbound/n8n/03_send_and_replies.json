    {
      "parameters": {
        "jsCode": "const input = $('Parse Telegram Input').first().json;\nconst allLeads = $input.all().map((item) => item.json);\nconst match = allLeads.find((row) => row.lead_id === input.lead_id) || {};\nreturn [{ json: { ...match, ...input } }];"
      },
