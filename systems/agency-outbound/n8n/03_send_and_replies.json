    {
      "parameters": {
        "jsCode": "const payload = $json.callback_query?.data || '';\nconst text = $json.message?.text || '';\nconst [action, leadId] = payload.split('|');\nreturn [{ json: { action, lead_id: leadId || '', text, callback_query: $json.callback_query || null } }];"
