        900
      ],
      "id": "1a3db876-d616-4948-963a-800f00f7de30",
      "name": "Normalize Reply"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent?key=YOUR_GEMINI_API_KEY",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"contents\":[{\"parts\":[{\"text\":\"You are classifying replies to an outbound email campaign for agency owners.\\n\\nOffer: lead response automation\\n\\nClassify the reply into one of:\\n- positive\\n- neutral\\n- objection\\n- unsubscribe\\n- not_relevant\\n\\nThen write a short suggested response.\\n\\nRules:\\n- If the message asks not to be contacted, use unsubscribe.\\n- If the message shows interest, use positive.\\n- Keep suggested_response under 100 words.\\n- Do not promise pricing or timelines.\\n- Output strict JSON only.\\n\\nReply Subject:\\n{{$json.subject}}\\n\\nReply Body:\\n{{$json.body_excerpt}}\\n\\nReturn:\\n{\\n  \\\"classification\\\": \\\"\\\",\\n  \\\"reason\\\": \\\"\\\",\\n  \\\"suggested_response\\\": \\\"\\\"\\n}\"}]}]}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -600,
        900
      ],
      "id": "1cb8daa0-7ac5-4dcb-adba-b1d55496ab15",
      "name": "Gemini Reply Classifier"
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\nconst clean = raw.replace(/^```json\\s*/i, '').replace(/^```/i, '').replace(/```$/i, '').trim();\nconst parsed = JSON.parse(clean);\nreturn [{ json: { ...$('Normalize Reply').first().json, ...parsed } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -360,
        900
      ],
      "id": "7d5d82fe-c5b7-4af9-908a-4798a75eef9a",
      "name": "Parse Reply JSON"
    },
    {
      "parameters": {
        "chatId": "YOUR_TELEGRAM_CHAT_ID",
        "text": "=Reply from {{$json.from_email}}\\nClassification: {{$json.classification}}\\nReason: {{$json.reason}}\\n\\nSuggested Response:\\n{{$json.suggested_response}}",
        "additionalFields": {}
