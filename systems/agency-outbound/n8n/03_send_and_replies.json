    {
      "parameters": {
        "jsCode": "return [{ json: { from_email: $json.From, subject: $json.Subject, body_excerpt: $json.snippet, gmail_thread_id: $json.threadId || '' } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
