      "id": "dbdf8c48-91d3-4a97-a698-b97db56d9d71",
      "name": "Read Leads For Send"
    },
    {
      "parameters": {
        "jsCode": "const configRows = $items('Read Config', 0).map((item) => item.json);\nconst config = Object.fromEntries(configRows.map((row) => [row.key, row.value]));\nif (String(config.send_enabled).toLowerCase() !== 'true') return [];\nconst leads = $items('Read Leads For Send', 0)\n  .map((item) => item.json)\n  .filter((row) => row.status === 'approved')\n  .slice(0, Math.max(1, Number(config.daily_send_limit || 10)));\nreturn leads.map((lead) => ({ json: { ...lead, _config: config } }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
