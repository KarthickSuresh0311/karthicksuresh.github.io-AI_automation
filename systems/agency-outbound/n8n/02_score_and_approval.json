{
  "name": "Agency Outbound - 02 Score And Approval",
  "description": "Reads new leads, fetches site context, scores fit with Gemini, drafts outreach, and sends Telegram approval cards.",
  "active": false,
  "isArchived": false,
  "nodes": [
