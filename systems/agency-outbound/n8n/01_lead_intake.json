{
  "name": "Agency Outbound - 01 Lead Intake",
  "description": "Reads RawLeads from Google Sheets, normalizes rows, filters duplicates, and appends clean leads into Leads.",
  "active": false,
  "isArchived": false,
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 15
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
